{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "*.tsbuildinfo"],
      "inputs": [
        "src/**",
        "tsconfig.json",
        "tsconfig.build.json",
        "tsup.config.ts",
        "tsup.config.js",
        "package.json"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": [],
      "inputs": ["src/**", "tests/**", "**/*.test.ts", "**/*.test.tsx"]
    },
    "lint": {
      "outputs": []
    },
    "format:check": {
      "outputs": []
    },
    "validate": {
      "cache": false
    },
